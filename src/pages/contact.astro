---
import BaseLayout from "../layouts/BaseLayout.astro";
import CardGrid from "../components/CardGrid.astro";
import Icon from "../components/Icon.astro";
import Section from "../components/Section.astro";
import Hero from "../components/Hero.astro";
import { site } from "../data/site";

const contactCards = [
  {
    eyebrow: "Community",
    icon: "discord",
    title: "Discord community",
    body: "Join the PSKC online community for direct conversation and local updates.",
    href: site.discord,
    action: "Join our Discord",
  },
  {
    eyebrow: "Follow",
    icon: "link",
    title: "Social links hub",
    body: "Find PSKC social channels, newsletters, and current public links in one place.",
    href: site.linksHub,
    action: "Open links hub",
  },
  {
    eyebrow: "Email",
    icon: "mail",
    title: "Inquiries",
    body: "Send questions, press notes, partnership ideas, or accessibility requests by email.",
    href: `mailto:${site.email}`,
    action: "Email PSKC",
  },
  {
    eyebrow: "Support",
    icon: "heart",
    title: "Donate",
    body: "Support community education, events, and harm reduction work in Kansas City.",
    href: site.donate,
    action: "Donate now",
  },
];
---

<BaseLayout
  title="Contact Us"
  description="Contact the Psychedelic Society of Kansas City for questions, collaborations, community links, and donation information."
>
  <Hero
    compact
    eyebrow="Contact"
    titleLines={["Reach PSKC."]}
    intro="Have a question, comment, or collaboration opportunity in mind? We would love to hear from you."
    image="/assets/images/PSKC%20FB_BANNER-01.jpeg"
    imageAlt="Kansas City skyline illustration with PSKC geometric artwork"
  />

  <Section>
    <CardGrid columns="four">
      {contactCards.map((card) => (
        <a class="contact-card" href={card.href} target={card.href.startsWith("http") ? "_blank" : undefined} rel={card.href.startsWith("http") ? "noopener noreferrer" : undefined}>
          <div class="contact-card__icon">
            <Icon name={card.icon} />
          </div>
          <p class="eyebrow">{card.eyebrow}</p>
          <h2>{card.title}</h2>
          <p>{card.body}</p>
          <span class="contact-card__link">
            {card.action}
          </span>
        </a>
      ))}
    </CardGrid>

    <form class="contact-form" action={`mailto:${site.email}`} method="post" enctype="text/plain">
      <p class="eyebrow">Enquiry Form</p>
      <h2 class="contact-form__title">Send a note</h2>
      <div class="form-grid mt-6">
        <div class="field">
          <label for="contact-name">Name</label>
          <input id="contact-name" name="name" autocomplete="name" required />
        </div>
        <div class="field">
          <label for="contact-email">Email</label>
          <input id="contact-email" name="email" type="email" autocomplete="email" required />
        </div>
        <div class="field field--wide">
          <label for="contact-topic">Topic</label>
          <input id="contact-topic" name="topic" required />
        </div>
        <div class="field field--wide">
          <label for="contact-message">Message</label>
          <textarea id="contact-message" name="message" required></textarea>
        </div>
      </div>
      <button class="button button--primary mt-6" type="submit">Send Email</button>
    </form>
  </Section>
</BaseLayout>
