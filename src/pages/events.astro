---
import BaseLayout from "../layouts/BaseLayout.astro";
import Button from "../components/Button.astro";
import Icon from "../components/Icon.astro";
import Section from "../components/Section.astro";
import Hero from "../components/Hero.astro";
import { exampleEvents } from "../data/exampleEvents";
import { site } from "../data/site";
---

<BaseLayout
  title="Upcoming Events"
  description="Upcoming Psychedelic Society of Kansas City events and monthly meetups."
>
  <Hero
    compact
    eyebrow="Events"
    titleLines={["Upcoming", "gatherings."]}
    intro="PSKC hosts public education events, monthly meetups, and community gatherings across Kansas City."
    image="/assets/images/kcpcbanner.jpg"
    imageAlt="Abstract KCPC mandala artwork used for PSKC event pages"
  >
    <Button slot="actions" href={site.luma} variant="primary">Open Lu.ma Calendar</Button>
    <Button slot="actions" href={site.luma} variant="secondary">Subscribe on Lu.ma</Button>
  </Hero>

  <Section eyebrow="Calendar" title="Upcoming events">
    <div class="event-mini-grid" aria-label="PSKC event focus areas">
      <a class="event-mini-card" href={site.luma} target="_blank" rel="noopener noreferrer">
        <Icon name="calendar" />
        <div>
          <h3 class="font-black">Monthly meetups</h3>
          <p>Public talks, panels, and peer conversation around psychedelic education and community care.</p>
        </div>
      </a>
      <a class="event-mini-card" href={site.luma} target="_blank" rel="noopener noreferrer">
        <Icon name="users" />
        <div>
          <h3 class="font-black">Community gatherings</h3>
          <p>Low-barrier ways to meet local organizers, practitioners, advocates, artists, and curious newcomers.</p>
        </div>
      </a>
    </div>

    <div class="example-event-list" aria-label="Example event listings">
      {exampleEvents.map((event) => (
        <a class="event-list-card" href={site.luma} target="_blank" rel="noopener noreferrer" aria-label={`View PSKC events for ${event.title}`}>
          <Icon name={event.icon} />
          <div>
            <p class="eyebrow">{event.label}</p>
            <h3>{event.title}</h3>
            <p>{event.body}</p>
          </div>
        </a>
      ))}
    </div>

    <div class="calendar-panel">
      <iframe
        class="luma-frame"
        src="https://lu.ma/embed/calendar/cal-WzYiUbVWw82gLyR/events?lt=light"
        title="Psychedelic Society of Kansas City Lu.ma events calendar"
        frameborder="0"
        allowfullscreen
        aria-hidden="false"
        tabindex="0"
      ></iframe>
    </div>
    <p class="mt-5 text-base">
      Having trouble viewing the embedded calendar?
      <a class="read-more-link" href={site.luma} target="_blank" rel="noopener noreferrer">
        Open the PSKC Lu.ma calendar.
      </a>
    </p>
  </Section>
</BaseLayout>
