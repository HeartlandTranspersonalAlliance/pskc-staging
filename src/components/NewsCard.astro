---
import type { CollectionEntry } from "astro:content";
import Icon from "./Icon.astro";
import { withBase } from "../utils/urls";

interface Props {
  post: CollectionEntry<"news">;
}

const { post } = Astro.props;
const date = post.data.date.toLocaleDateString("en-US", {
  month: "long",
  day: "numeric",
  year: "numeric",
});
const primaryCategory = post.data.categories[0] ?? "Update";
---

<article class="news-card" data-news-card data-categories={post.data.categories.join("|")}>
  {
    post.data.image ? (
      <img
        class="news-card__thumb"
        src={withBase(post.data.image)}
        alt={post.data.imageAlt ?? ""}
        loading="lazy"
      />
    ) : (
      <div class="news-card__mark" aria-hidden="true">
        <Icon name={primaryCategory === "Advocacy" ? "advocacy" : "policy"} />
      </div>
    )
  }
  <div>
    <p class="eyebrow">{date}</p>
    <h2>
      <a href={withBase(`/${post.id}/`)}>{post.data.title}</a>
    </h2>
    <p>{post.data.description}</p>
    <div class="tag-row" aria-label="Post categories">
      {post.data.categories.map((category) => <span>{category}</span>)}
    </div>
    <a class="read-more-link" href={withBase(`/${post.id}/`)} aria-label={`Read more about ${post.data.title}`}>
      Read more
    </a>
  </div>
</article>
