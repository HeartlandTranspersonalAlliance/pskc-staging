---
import { withBase } from "../utils/urls";

interface Props {
  eyebrow?: string;
  titleLines: string[];
  intro?: string;
  image: string;
  imageAlt?: string;
  compact?: boolean;
  tone?: "default" | "warm";
}

const {
  eyebrow,
  titleLines,
  intro,
  image,
  imageAlt = "",
  compact = false,
  tone = "default",
} = Astro.props;
const resolvedImage = withBase(image);
---

<section
  class:list={[
    "hero-shell",
    compact && "hero-shell--compact",
    tone !== "default" && `hero-shell--${tone}`,
  ]}
>
  <img class="hero-image" src={resolvedImage} alt={imageAlt} loading={compact ? "lazy" : "eager"} decoding="async" />
  <div class="site-container hero-content">
    {eyebrow && <p class="eyebrow hero-eyebrow">{eyebrow}</p>}
    <h1>
      {titleLines.map((line) => <span>{line}</span>)}
    </h1>
    {intro && <p class="hero-intro">{intro}</p>}
    <div class="hero-actions">
      <slot name="actions" />
    </div>
  </div>
</section>
