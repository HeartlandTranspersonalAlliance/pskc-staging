---
interface Props {
  eyebrow?: string;
  title?: string;
  intro?: string;
  tone?: "paper" | "ink" | "mist";
  class?: string;
}

const {
  eyebrow,
  title,
  intro,
  tone = "paper",
  class: className = "",
} = Astro.props;

---

<section class:list={["section-band", `section-tone-${tone}`, className]}>
  <div class="site-container">
    {(eyebrow || title || intro) && (
      <div class="section-heading">
        {eyebrow && <p class="eyebrow">{eyebrow}</p>}
        {title && <h2>{title}</h2>}
        {intro && <p>{intro}</p>}
      </div>
    )}
    <slot />
  </div>
</section>
