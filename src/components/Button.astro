---
import { withBase } from "../utils/urls";

interface Props {
  href: string;
  variant?: "primary" | "secondary" | "light" | "outline";
  class?: string;
  ariaLabel?: string;
}

const {
  href,
  variant = "primary",
  class: className = "",
  ariaLabel,
} = Astro.props;
const external = /^https?:\/\//i.test(href);
const resolvedHref = withBase(href);
---

<a
  href={resolvedHref}
  target={external ? "_blank" : undefined}
  rel={external ? "noopener noreferrer" : undefined}
  aria-label={ariaLabel}
  class:list={[
    "button",
    `button--${variant}`,
    className,
  ]}
>
  <slot />
</a>
